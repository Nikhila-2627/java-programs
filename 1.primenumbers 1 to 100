//Write a Java program which selects and prints all the prime numbers within the range of 1 to 100.
public class PrimeNumbersAppl {
public static void main(String[] args) {
System.out.println("Prime numbers between 1 and 100 are:");
for (int num = 2; num <= 100; num++) {
boolean isPrime = true;
// Check if num is divisible by any number from 2 to num/2
for (int i = 2; i <= num / 2; i++) {
if (num % i == 0) {
isPrime = false;
break;
}
}
// Print num if it is prime
if (isPrime) {
System.out.print(num + " ");
}
}
}
}
